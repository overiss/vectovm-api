IS_DEBUG=true

HTTP_NAME=vectovm-api
HTTP_PORT=:8081

POSTGRES_DSN=postgres://vectovm:vectovm@localhost:5433/vectovm?sslmode=disable
POSTGRES_MAX_CONNS=10
POSTGRES_MIN_CONNS=2

OAUTH_ISSUER=http://localhost:8080
OAUTH_CLIENT_ID=your-web-client-id
OAUTH_CLIENT_SECRET=your-web-client-secret
OAUTH_REDIRECT_URI=http://localhost:8081/api/v1/auth/callback

MAPI_BASE_URL=https://localhost:8443
MAPI_BEARER_TOKEN=your-mapi-bearer-token
MAPI_CA_CERT_FILE=ca.crt

VAULT_ADDRESS=http://127.0.0.1:8200
VAULT_TOKEN=dev-root-token
VAULT_CREDENTIALS_KEY_PATH=secret/data/vectovm-api/credentials
